# Database
DATABASE_URL="postgresql://oils:oils@localhost:5432/oils"

# Public base URL (used in PDF QR codes and shareable blend links)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Site display name — shown in the header, footer, page titles, and PDF
# Change this to brand your deployment (e.g. "My Aromatherapy Studio")
NEXT_PUBLIC_SITE_NAME="Potions & Lotions"

# Admin panel password — set to any strong secret value
ADMIN_SECRET="change-me"

# Cron purge endpoint secret — set to any strong secret value
# Used by the host-side cron job to authenticate /api/cron/purge
CRON_SECRET="change-me"

# Google Analytics 4 Measurement ID (optional)
# Omit or leave blank to disable analytics entirely
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Anthropic API key — only required to run `npm run enrich`
# Not needed for normal operation or seeding
ANTHROPIC_API_KEY=""
